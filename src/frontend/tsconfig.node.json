{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "emitDeclarationOnly": true,
    "composite": true,
    "declaration": true,
    "isolatedModules": true
  },
  "include": ["vite.config.ts", "vitest.config.ts", "eslint.config.js"]
}
