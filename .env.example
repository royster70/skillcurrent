# SkillCurrent backend configuration.
# Copy to src/backend/.env and adjust. Every variable here maps to a field in
# src/backend/app/core/config.py (pydantic-settings).

# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/workforce_ai

# Root directory holding all external source datasets, outside the repo
# (see docs/INGESTION_RUNBOOK.md for the expected Data/ layout).
DATA_ROOT=./data

# ── Optional ────────────────────────────────────────────────────────────────
# Anthropic API token — needed only for the AI company-classification feature
# (CompanyLookup). Leave empty to run without it.
ANTHROPIC_AUTH_TOKEN=

# O*NET release the platform is pinned to (stamped on every derived record).
ONET_VERSION=28.1

# Observability (ADR-007): persist every API request to api_request_log.
ENABLE_REQUEST_LOGGING=false

# Data refresh pipeline (FR-8.8): APScheduler auto-run + cron (default Sun 2am).
PIPELINE_AUTO_RUN=false
PIPELINE_SCHEDULE_CRON=0 2 * * 0

# ── Per-dataset path overrides ──────────────────────────────────────────────
# Each dataset defaults to $DATA_ROOT/<subdir>; override one only if a machine
# deviates from the standard layout.
# NOTE: these are read via os.environ, NOT from this file — export them as real
# environment variables (e.g. in your shell profile), not as .env entries.
#   ONET_DATA_PATH             default $DATA_ROOT/ONet
#   ELOUNDOU_DATA_PATH         default $DATA_ROOT/OpenAI-Exposure-Score
#   MICROSOFT_AI_DATA_PATH     default $DATA_ROOT/microsoft-working-with-ai
#   AEI_DATA_PATH              default $DATA_ROOT/AEI
#   AEI_TEMPORAL_DATA_PATH     default $DATA_ROOT/AEI/AEI-full
#   OEWS_DATA_PATH             default $DATA_ROOT/BLS/oesm24in4
#   GDPVAL_DATA_PATH           default $DATA_ROOT/GDPval
#   OSCA_DATA_PATH             default $DATA_ROOT/OSCA
#   ASC_DATA_PATH              default $DATA_ROOT/ASC
#   ABS_DATA_PATH              default $DATA_ROOT/ABS
#   ANZSCO_DATA_PATH           default $DATA_ROOT/ANZSCO
#   CENSUS_DATA_PATH           default $DATA_ROOT/ABS-2021-Census
#   CENSUS_SUBDIVISION_L2_FILE / CENSUS_SUBDIVISION_L3_FILE  (full file paths)
